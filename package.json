{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@nozomiishii/renovate",
  "version": "0.0.0",
  "description": "🦄 Reborn Renovate",
  "keywords": [
    "renovate",
    "config"
  ],
  "homepage": "https://github.com/nozomiishii/renovate#readme",
  "bugs": {
    "url": "https://github.com/nozomiishii/renovate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nozomiishii/renovate.git"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "main": "default.json",
  "bin": "bin/cli.sh",
  "scripts": {
    "format": "pnpm prettier . --check",
    "format:fix": "pnpm prettier . --write",
    "postinstall": "postinstall",
    "prettier": "prettier --ignore-unknown --cache",
    "validate": "renovate-config-validator --strict default.json"
  },
  "devDependencies": {
    "@nozomiishii/commitlint-config": "1.2.0",
    "@nozomiishii/lefthook-config": "1.2.0",
    "@nozomiishii/markdownlint-cli2-config": "1.2.0",
    "@nozomiishii/postinstall": "1.2.0",
    "@nozomiishii/prettier-config": "1.2.0",
    "lefthook": "2.1.8",
    "renovate": "43.150.0"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": "24.16.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
